            <string name="revanced_gms_core_dialog_cancel_text">ರದ್ದುಮಾಡಿ</string>
            <string name="revanced_gms_core_dialog_not_whitelisted_using_battery_optimizations_message">"ಸಮಸ್ಯೆಗಳನ್ನು ತಡೆಗಟ್ಟಲು MicroG GmsCore ಬ್ಯಾಟರಿ ಆಪ್ಟಿಮೈಸೇಶನ್‌ಗಳನ್ನು ನಿಷ್ಕ್ರಿಯಗೊಳಿಸಬೇಕು.\n\nMicroG ಗಾಗಿ ಬ್ಯಾಟರಿ ಆಪ್ಟಿಮೈಸೇಶನ್‌ಗಳನ್ನು ನಿಷ್ಕ್ರಿಯಗೊಳಿಸುವುದು ಬ್ಯಾಟರಿ ಬಳಕೆಗೆ ನಕಾರಾತ್ಮಕವಾಗಿ ಪರಿಣಾಮ ಬೀರುವುದಿಲ್ಲ.\n\nಮುಂದುವರಿ ಬಟನ್ ಅನ್ನು ಟ್ಯಾಪ್ ಮಾಡಿ ಮತ್ತು ಆಪ್ಟಿಮೈಸೇಶನ್ ಬದಲಾವಣೆಗಳನ್ನು ಅನುಮತಿಸಿ."</string>
            <string name="revanced_gms_core_dialog_continue_text">ಮುಂದುವರಿಸಿ</string>
        </patch>
